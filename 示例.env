# ========== Web 认证 ==========
# 管理员登录密码（必填）
WEB_PASSWORD=your_secure_password_here

# 用于加密 Cookie 的密钥（必填，建议 32 位以上随机字符串）
WEB_AUTH_SECRET=your_random_secret_key_32chars

# ========== 数据库配置 ==========
# MySQL/MariaDB 连接信息（必填）
DB_HOST=localhost
DB_PORT=3306
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=your_database_name

# ========== 服务端口 ==========
# HTTP 服务端口（默认 3233）
PORT=3233

# ========== 可选：日志级别 ==========
# 可选值: error, warn, info, debug
LOG_LEVEL=info

# ========== 可选：性能统计阈值 ==========
# CPU 变化阈值（百分比），低于此值不触发更新
MC_STATS_CPU_THRESHOLD=0.5

# 内存变化阈值（字节），低于此值不触发更新
MC_STATS_MEM_THRESHOLD=1048576

# ========== 可选：并发控制 ==========
# pidusage 并发数
PIDUSAGE_CONCURRENCY=3